<script>
const canvas = document.getElementById('fluidCanvas');
const ctx = canvas.getContext('2d');
let particles = [];
let mouse = { x: null, y: null };

window.addEventListener('mousemove', (e) => { mouse.x = e.clientX; mouse.y = e.clientY; });
window.addEventListener('touchmove', (e) => { mouse.x = e.touches[0].clientX; mouse.y = e.touches[0].clientY; });

function initCanvas() { 
  canvas.width = window.innerWidth; 
  canvas.height = window.innerHeight; 
}
window.addEventListener('resize', initCanvas);
initCanvas();

class FluidParticle {
  constructor() {
    this.x = Math.random() * canvas.width;
    this.y = Math.random() * canvas.height;
    this.size = Math.random() * 2 + 0.8;
    this.speedX = (Math.random() - 0.5) * 0.6;
    this.speedY = (Math.random() - 0.5) * 0.6;
    this.color = Math.random() > 0.6 ? 'rgba(212, 175, 55, 0.4)' : 'rgba(255, 117, 160, 0.4)';
  }
  update() {
    this.x += this.speedX; this.y += this.speedY;
    if (this.x < 0 || this.x > canvas.width) this.speedX *= -1;
    if (this.y < 0 || this.y > canvas.height) this.speedY *= -1;

    let dx = mouse.x - this.x;
    let dy = mouse.y - this.y;
    let distance = Math.sqrt(dx * dx + dy * dy);
    if (distance < 120) {
      this.x -= dx * 0.015;
      this.y -= dy * 0.015;
    }
  }
  draw() {
    ctx.beginPath();
    ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
    ctx.fillStyle = this.color;
    ctx.fill();
  }
}

function togglePassVisibility() {
  const passInput = document.getElementById("pass");
  const icon = document.querySelector(".toggle-password");
  if (passInput.type === "password") {
    passInput.type = "text";
    icon.classList.replace("fa-eye-slash", "fa-eye");
  } else {
    passInput.type = "password";
    icon.classList.replace("fa-eye", "fa-eye-slash");
  }
}

function launchSurprise() {
  let u = document.getElementById("user").value.trim().toLowerCase();
  let p = document.getElementById("pass").value.trim();
  
  if (u === "lwin phyo aung" && p === "20.2.2026") {
    let card = document.getElementById("fb-card");
    card.style.opacity = "0";

    setTimeout(() => {
      card.style.display = "none";
      let loader = document.getElementById("loader-screen");
      loader.style.display = "flex";
    }, 400);

    setTimeout(() => {
      document.getElementById("loader-screen").style.display = "none";
      document.getElementById("fb-feed-screen").style.display = "block";
    }, 3500);

  } else {
    document.getElementById("fb-error").style.display = "block";
  }
}

function openGift() {
  // Mobile Audio Block မဖြစ်အောင် play() ကို အပေါ်ဆုံးမှာ ကြိုတင်ပတ်ထားပေးသည်
  let audio = document.getElementById("bgMusic");
  audio.volume = 0.8;
  audio.play().catch(e => console.log("Audio Stream Ready"));

  let feedScreen = document.getElementById("fb-feed-screen");
  feedScreen.style.opacity = "0";
  
  setTimeout(() => {
    feedScreen.style.display = "none";
    let universe = document.getElementById("universe-zone");
    universe.style.display = "block";
    
    setTimeout(() => { 
      universe.style.opacity = "1"; 
      document.getElementById("main-card").style.transform = "scale(1)";
    }, 50);

    for (let i = 0; i < 100; i++) { particles.push(new FluidParticle()); }
    animateUniverse();
    typeTextStream();
  }, 500);
}

function animateUniverse() {
  ctx.fillStyle = 'rgba(11, 7, 19, 0.15)';
  ctx.fillRect(0, 0, canvas.width, canvas.height);
  particles.forEach(p => { p.update(); p.draw(); });
  requestAnimationFrame(animateUniverse);
}

// Zawgyi စာသားများ
const longLetter = `Happy 4 Monthsary ပါေနာ္အခ်စ္ သဲငယ္ကို တစ္ေန႔ထက္တစ္ေန႔ ပိုခ်စ္တာကလြဲရင္ ေျပာင္းလဲသြားတာမရွိပါဘူးေနာ္။ အခ်စ္ေတြ ပိုေလးနက္လာတာပဲ ရွိတာပါဗ်။ ေ၀းဖို႔လည္း ေတြးေၾကာက္မေနပါနဲ႔ေနာ္။ ေမာင္က သဲကို ေရြးခ်ယ္ၿပီးသားျဖစ္တဲ့အတြက္ေၾကာင့္မို႔လို႔ ဆံုးရွံဳးမခံေတာ့ပါဘူးဗ်။ ေမာင့္အပိုင္လို႔ ယူဆၿပီးတဲ့အတြက္ေၾကာင့္ သဲက ေမာင့္အပိုင္ပါပဲေနာ္။ ေမာင့္ကို သဲလက္ထဲကေန ဘယ္သူမွ လုယူလို႔မရပါဘူးဗ်။

မိန္းကေလးဆိုလို႔ ေမာင့္မိန္းမေလးျဖစ္တဲ့ "ႏွင္းအိလႈိင္" ဆိုတဲ့ အမ်ိဳးသမီးေလးကလြဲလို႔ က်န္တဲ့မိန္းကေလးဆို မ်က္ေစာင္းမွ်ေယာင္လို႔မွ မထိုးပါေနာ္။ ေမာင့္ႏွလံုးသားက သဲကျပဳစားၿပီး အပိုင္ယူၿပီးသြားပါၿပီဗ်။ သဲအပိုင္လို႔ ေမာင့္ကိုယူဆလို႔ရပါၿပီေနာ္။ ပ်က္ဆဲဖို႔မဟုတ္ဘဲ လက္ထပ္ဖို႔ ေရြးခ်ယ္ခ်စ္ခဲ့တာပါဗ်။ ဘယ္ေလာက္ထိ ေတြးထားလဲဆို အဂၤုလိမာလသုတ္တန္ ႀကိဳက်က္ထားပါၿပီဗ်။

ဒါနဲ႔ သဲဗိုက္ေအာင့္တဲ့ေန႔ကေလ ေမာင္တစ္ညလံုးမအိပ္ဘူးသဲရ။ ေမာင္ဘုရားရွိခိုးတယ္၊ တရားထိုင္တယ္၊ သဲသက္သာပါေစေတာင္းေနတာ။ သဲငယ္ေလးရယ္ ဂရုစုိက္မွပ့ါကြ။ ေမာင့္မွာ ခ်စ္စရာဆိုလို႔ ဒီတစ္ေယာက္ေလးပဲရွိတာ။ လူက ေပါ့တီးေပါ့ဆ၊ ေခါင္းမ်ားေပါက္ရေသးတယ္။ ေမာင္ေမာင္ ရုိက္ပစ္လိုက္မယ္ေနာ့ အဲ့ေဇာင္းကို။ ေမာင္ေမာင္သာရွိရင္ အဲ့ဒါကို ခ်ိဳးပစ္မွာ။ ေမာင့္ကေလးေလး သနားပါတယ္၊ ေမာင့္မိန္းမေလးကို ကိုယ္၀န္ေဆာင္ရင္ေကာ မေဆာင္ခင္ေကာကို လွက္ခါးအတက္အဆင္းပါ လိုက္ပို႔ေပးရမယ္။ ကေျပာင္ကပ်က္ေတြ ျပဳတ္က်ေနမွ နာေနမယ္ ေမာင့္မိန္းမေလးရယ္။ ခ်စ္လို႔စတာေလ ဘာလို႔ တကယ္စားတာလဲ၊ စားမွဳေတာ့ ေအာင့္ၿပီေပါ့။ ေမာင္က ၅ ေတာင့္ စားလိုက္တယ္။ သဲကိုစားခိုင္းလို႔ အျပစ္ေပးတာ။ နဖူးေလး ေရာင္ေနတာလဲ ေမာင္သိတာေပါ့ ေမာင္ျမင္တယ္။ ၾကပ္ထုပ္ထိုးေပးခ်င္လိုက္တာ ငါ့မိန္းကေလးေခါင္းကို။

ေမာင့္သဲေလးကို ဘယ္ေလာက္ခ်စ္ေၾကာင္း သိေစခ်င္ပါတယ္ေနာ္။ ဆံျဖဴသြားက်ိဳး ခါးေတြကုန္းတဲ့ထိ ဒီအမ်ိဳးသမီးတစ္ေယာက္ေလးကို ဒီထက္အမွ်ပိုတဲ့အခ်စ္နဲ႔ သက္ဆံုးတိုင္ ဘ၀ဆံုးတိုင္ ခ်စ္သြားပါမယ္ဗ်။ ေမာင့္အခ်စ္ကိုလဲ ယံုယံုၾကည္ၾကည္နဲ႔ တစ္သက္လံုး ခ်စ္သြားေပးပါေနာ္။ ေမာင့္ကို စိတ္မပ်က္ပါနဲ႔ေနာ္။ ေမာင္ေမာင္ကဆိုးလို႔ သဲေလးပစ္သြားမှာကို အရမ္းေၾကာက္ပါတယ္ေနာ္။ ထာ၀ရထက္ တစ္ရက္ပိုခ်စ္တာပါဗ်။

ေမာင့္အခ်စ္ကို စစေတြ႔ခ်င္းတုန္းက အသိအမွတ္ျပဳေပးတဲ့အတြက္ ေမာင္က အတိုင္းထက္အလြန္ကို ေက်းဇူးတင္ပါတယ္ေနာ္။ ေမာင့္ရဲ႔ ခ်စ္စရာဆိုတဲ့ အမ်ိဳးသမီးေလးက သဲတစ္ေယာက္ထဲပါေနာ္။ မိန္းမလို႔ ေခၚခဲ့တာက အလကားေခၚတာမဟုတ္ပါဘူးေနာ္၊ ရည္ရြယ္ၿပီး ေခၚတာပါဗ်။ ေမာင့္ရဲ႔အသက္ ေမာင့္ရဲ႔အရာရာက သဲေလးလို႔ ယူဆၿပီးပါၿပီေနာ္။ ေမာင့္အခ်စ္က သဲကို ထာ၀ရထက္ တစ္ရက္ပိုကို ခ်စ္တာပါေနာ္။

ေမာင့္စိတ္ေလးက တစ္ခါတစ္ေလ စိတ္တိုတတ္တာက သဲကိုတိုတာမဟုတ္ဘူးေနာ္၊ ေမာင့္အက်င့္ေတြကို တိုတာေနာ္။ သဲေလးကို ေမာင္က မ်က္ႏွာေလးေတာင္ ပ်က္ျပတာမဟုတ္ဘူး မိန္းမရဲ႔။ ဘာလို႔ဆို မိန္းမက ေယာက္်ားမၿပံုးရင္ေတာင္ ငိုတတ္တဲ့သူေလ။ ေမာင္လူေရြးမွန္ၿပီ ထင္ပါတယ္ဗ်။ ခုလို ေမာင့္ဘ၀ထဲ ေရာက္လာေပးလို႔ ေက်းဇူးတင္ပါတယ္ဗ်။ ေမာင့္အိမ္ရွင္မေလးအျဖစ္ တစ္သက္လံုး ေနေပးပါေနာ္။kေမာင့္ကမၻာငယ္ေလးေရ နလံုးသားတစ္ခုလံုးအပိုင္သိမ္းသြားၿပီမို႔ေမာင့္အခ်စ္ကေလးနက္လြန္းပါတယ္ တစ္ခါတစ္ေလေမ့တက္တာေလးေတာ့ခြင့္လႊတ္ေပးပါေနာ္ ေမာင္ေမာင္ကသဲကိုကေမးမွာ ဒါေပမယ့္ေမ့သြားေတာ့အေလးမထားသလိုျဖစ္ေရာေမာင္ကတကယ္ကေမ့သြားတာ ေမာင့္သဲေလးရယ္ သဲထင္ထားတာထက္ပိုၿပီးေလးနက္ေၾကာင္း ဒီဟာေလးနဲ႔သက္ေသျပလိုက္ပါတယ္ေနာ္ တစ္ရက္ေလာက္လုပ္ထားရတာမို႔ သဲႀကိဳက္မယ္လို႔ေမ်ွာ္လင့္ပါတယ္ဗ်အရမ္းခ်စ္တယ္။`;

let charIdx = 0;
function typeTextStream() {
