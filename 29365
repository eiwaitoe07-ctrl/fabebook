    justify-content: center;
    align-items: center;
  }
  .fb-spinner div {
    width: 10px;
    height: 10px;
    margin: 0 5px;
    background: #bcc0c4;
    border-radius: 50%;
    animation: fb-bounce 0.6s infinite alternate;
  }
  .fb-spinner div:nth-child(2) { animation-delay: 0.2s; }
  .fb-spinner div:nth-child(3) { animation-delay: 0.4s; }

  @keyframes fb-bounce {
    to { transform: translateY(-12px); background: #606770; }
  }

  /* 📱 STEP 3: REAL FB NEWS FEED SURPRISE */
